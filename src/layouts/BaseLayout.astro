<!-- Base layout component for an Elderly Home Starter Template -->

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Elderly Home</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        /* Custom styles for expandable content */
        .expandable {
            display: none;
        }
        .expandable.active {
            display: block;
        }
        
        /* Custom styles for lightbox */
        .lightbox {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            overflow: auto;
            background-color: rgba(0, 0, 0, 0.8);
        }
        
        /* Custom styles for image slider */
        .slider {
            position: relative;
            max-width: 100%;
            margin: auto;
        }
    </style>
</head>
<body class="bg-gray-100">
    <header class="bg-blue-500 p-4 text-white">
        <h1 class="text-2xl">Elderly Home</h1>
    </header>
    <main class="container mx-auto p-4">
        <slot />
    </main>
    <footer class="bg-blue-500 p-4 text-white text-center">
        <p>&copy; 2026 Elderly Home. All rights reserved.</p>
    </footer>
</body>
</html>
